{
  "name": "surepay-one/sdk",
  "description": "Official PHP SDK for the SurePay Payment Gateway API",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "SurePay\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SurePay\\Tests\\": "tests/"
    }
  }
}
